<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Fixtures 2025/26</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --gold: #FFD700;
      --gold2: #FFA500;
      --bg: #080c14;
      --card: #0f1623;
      --card2: #141d2e;
      --border: rgba(255,215,0,0.12);
      --text: #e8eaf0;
      --muted: rgba(255,255,255,0.4);
      --live: #00ff87;
      --finished: rgba(255,255,255,0.5);
      --scheduled: #FFD700;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg); color: var(--text);
      font-family: 'DM Sans', sans-serif;
      min-height: 100vh; padding: 28px 20px;
      background-image:
        radial-gradient(ellipse 80% 50% at 10% 0%, rgba(255,165,0,0.07) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 90% 100%, rgba(30,80,180,0.1) 0%, transparent 55%);
    }

    /* HEADER */
    .header {
      max-width: 1100px; margin: 0 auto 36px;
      display: flex; justify-content: space-between; align-items: flex-end;
      padding-bottom: 20px; border-bottom: 1px solid var(--border);
    }
    .header-left { display: flex; flex-direction: column; gap: 6px; }
    .header-eyebrow { font-size: 11px; font-weight: 600; letter-spacing: 3px; text-transform: uppercase; color: var(--gold2); }
    .header-title { font-family: 'Bebas Neue', sans-serif; font-size: 52px; line-height: 1; color: white; letter-spacing: 2px; }
    .header-title span { color: var(--gold); }
    .header-sub { font-size: 13px; color: var(--muted); margin-top: 4px; }
    .header-right { display: flex; gap: 10px; align-items: center; }
    .nav-btn {
      background: transparent; color: var(--muted); padding: 9px 20px; border-radius: 30px;
      text-decoration: none; font-weight: 500; font-size: 13px;
      border: 1px solid rgba(255,255,255,0.12); transition: all 0.2s;
    }
    .nav-btn:hover { border-color: var(--gold); color: var(--gold); }

    .status-pill {
      display: inline-flex; align-items: center; gap: 7px;
      padding: 6px 16px; border-radius: 30px; font-size: 11px; font-weight: 700; letter-spacing: 1.5px;
    }
    .status-pill.live { background: rgba(0,255,135,0.1); color: #00ff87; border: 1px solid rgba(0,255,135,0.25); }
    .status-pill.live::before { content:''; width:7px; height:7px; background:#00ff87; border-radius:50%; animation: blink 1.5s infinite; }
    .status-pill.loading { background: rgba(255,215,0,0.1); color: var(--gold); border: 1px solid rgba(255,215,0,0.2); }
    .status-pill.error { background: rgba(255,100,100,0.1); color: #ff6464; border: 1px solid rgba(255,100,100,0.25); }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* LEAGUE BAR */
    .league-bar {
      max-width: 1100px; margin: 0 auto 24px;
      display: flex; gap: 10px; flex-wrap: wrap;
    }
    .league-btn {
      background: var(--card); color: var(--muted);
      border: 1px solid rgba(255,255,255,0.08);
      padding: 11px 20px; border-radius: 12px;
      cursor: pointer; font-weight: 600; font-size: 14px;
      font-family: 'DM Sans', sans-serif;
      transition: all 0.2s; white-space: nowrap;
    }
    .league-btn:hover { background: rgba(255,215,0,0.08); border-color: rgba(255,215,0,0.3); color: var(--gold); transform: translateY(-2px); }
    .league-btn.active { background: linear-gradient(135deg, rgba(255,165,0,0.2), rgba(255,215,0,0.1)); border-color: var(--gold); color: var(--gold); box-shadow: 0 4px 24px rgba(255,215,0,0.15); transform: translateY(-2px); }
    .league-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    /* MATCHDAY CONTROLS */
    .matchday-bar {
      max-width: 1100px; margin: 0 auto 28px;
      display: flex; align-items: center; justify-content: center; gap: 16px;
    }
    .md-arrow {
      background: var(--card); color: var(--muted);
      border: 1px solid rgba(255,255,255,0.08);
      width: 40px; height: 40px; border-radius: 10px;
      cursor: pointer; font-size: 18px; font-family: 'DM Sans', sans-serif;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.2s;
    }
    .md-arrow:hover { border-color: var(--gold); color: var(--gold); background: rgba(255,215,0,0.08); }
    .md-arrow:disabled { opacity: 0.3; cursor: not-allowed; }
    .md-label {
      font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 2px;
      color: white; min-width: 160px; text-align: center;
    }
    .md-label span { color: var(--gold); }

    /* MAIN CARD */
    .main-card {
      max-width: 1100px; margin: 0 auto;
      background: var(--card); border-radius: 20px;
      border: 1px solid var(--border);
      overflow: hidden; box-shadow: 0 24px 80px rgba(0,0,0,0.5);
    }
    .card-header {
      padding: 20px 28px; display: flex; justify-content: space-between; align-items: center;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      background: linear-gradient(135deg, rgba(255,165,0,0.05), transparent);
    }
    .card-title { font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 1px; color: var(--gold); }
    .card-meta { font-size: 12px; color: var(--muted); margin-top: 2px; }

    /* DATE GROUP */
    .date-group { padding: 0 24px; }
    .date-label {
      font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
      color: var(--muted); padding: 18px 0 10px;
      border-bottom: 1px solid rgba(255,255,255,0.04); margin-bottom: 4px;
    }

    /* MATCH CARD */
    .match-card {
      display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: center; gap: 16px;
      padding: 16px 12px; border-radius: 12px;
      cursor: pointer; transition: background 0.15s; margin-bottom: 4px;
    }
    .match-card:hover { background: rgba(255,255,255,0.03); }

    .team { display: flex; align-items: center; gap: 12px; }
    .team.away { flex-direction: row-reverse; }
    .team-crest { width: 36px; height: 36px; object-fit: contain; flex-shrink: 0; }
    .team-crest-placeholder { width: 36px; height: 36px; background: rgba(255,215,0,0.1); border-radius: 50%; flex-shrink: 0; }
    .team-name { font-weight: 600; font-size: 14px; color: white; }
    .team.away .team-name { text-align: right; }
    .team-name.winner { color: var(--gold); }

    /* SCORE CENTER */
    .score-center { display: flex; flex-direction: column; align-items: center; gap: 6px; min-width: 100px; }
    .score-display { font-family: 'Bebas Neue', sans-serif; font-size: 28px; letter-spacing: 3px; color: white; line-height: 1; }
    .score-display.live-score { color: var(--live); }

    .match-status {
      display: inline-flex; align-items: center; gap: 5px;
      padding: 3px 10px; border-radius: 20px;
      font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase;
    }
    .ms-live { background: rgba(0,255,135,0.15); color: var(--live); border: 1px solid rgba(0,255,135,0.3); }
    .ms-live::before { content:''; width:6px; height:6px; background:var(--live); border-radius:50%; animation: blink 1.5s infinite; }
    .ms-finished { background: rgba(255,255,255,0.05); color: var(--finished); border: 1px solid rgba(255,255,255,0.1); }
    .ms-scheduled { background: rgba(255,215,0,0.08); color: var(--gold); border: 1px solid rgba(255,215,0,0.2); }
    .ms-postponed { background: rgba(255,100,100,0.08); color: #ff6464; border: 1px solid rgba(255,100,100,0.2); }

    .kickoff-time { font-size: 13px; font-weight: 600; color: var(--gold); }
    .ht-score { font-size: 11px; color: var(--muted); }

    /* MATCH DETAIL PANEL */
    .detail-panel {
      background: var(--card2); border-radius: 10px;
      padding: 16px 20px; margin: 0 12px 8px;
      border: 1px solid rgba(255,215,0,0.1);
      display: none; animation: fadeIn 0.2s ease;
    }
    .detail-panel.open { display: block; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(-6px)} to{opacity:1;transform:translateY(0)} }
    .detail-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; }
    .detail-item { display: flex; flex-direction: column; gap: 4px; }
    .detail-label { font-size: 10px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); }
    .detail-value { font-size: 13px; font-weight: 600; color: white; }
    .ht-row { margin-top: 12px; padding-top: 12px; border-top: 1px solid rgba(255,255,255,0.05); display: flex; gap: 24px; flex-wrap: wrap; }

    /* LOADING */
    .loading-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 20px; gap: 18px; }
    .spinner { width: 44px; height: 44px; border: 3px solid rgba(255,215,0,0.1); border-top-color: var(--gold); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to{transform:rotate(360deg)} }
    .loading-text { font-size: 14px; color: var(--muted); }
    .empty-state { padding: 60px 20px; text-align: center; color: var(--muted); font-size: 14px; }

    .footer-note { max-width: 1100px; margin: 20px auto 0; text-align: center; font-size: 12px; color: rgba(255,255,255,0.2); }

    @media (max-width: 640px) {
      .header { flex-direction: column; align-items: flex-start; gap: 16px; }
      .header-title { font-size: 36px; }
      .league-btn { padding: 9px 14px; font-size: 13px; }
      .team-name { font-size: 12px; }
      .score-display { font-size: 22px; }
      .match-card { gap: 8px; padding: 12px 8px; }
    }
  </style>
</head>
<body>

  <!-- HEADER -->
  <div class="header">
    <div class="header-left">
      <span class="header-eyebrow">📅 2025 / 26 Season</span>
      <h1 class="header-title">Fix<span>tures</span></h1>
      <p class="header-sub">Match schedule, results and live scores</p>
    </div>
    <div class="header-right">
      <span id="status-pill" class="status-pill loading">LOADING</span>
      <a href="/standings" class="nav-btn">📊 Standings</a>
      <a href="/scorers" class="nav-btn">⚽ Scorers</a>
      <a href="/" class="nav-btn">← Home</a>
    </div>
  </div>

  <!-- LEAGUE BUTTONS -->
  <div class="league-bar">
    <button class="league-btn" data-league="PL">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Premier League</button>
    <button class="league-btn" data-league="PD">🇪🇸 La Liga</button>
    <button class="league-btn" data-league="BL1">🇩🇪 Bundesliga</button>
    <button class="league-btn" data-league="SA">🇮🇹 Serie A</button>
    <button class="league-btn" data-league="FL1">🇫🇷 Ligue 1</button>
  </div>

  <!-- MATCHDAY CONTROLS -->
  <div class="matchday-bar">
    <button class="md-arrow" id="btn-prev">‹</button>
    <div class="md-label">Matchday <span id="md-num">—</span></div>
    <button class="md-arrow" id="btn-next">›</button>
  </div>

  <!-- MAIN CARD -->
  <div class="main-card">
    <div class="card-header">
      <div>
        <div class="card-title" id="card-title">Loading...</div>
        <div class="card-meta" id="card-meta"></div>
      </div>
      <span id="update-time" style="font-size:12px;color:var(--muted)"></span>
    </div>
    <div id="fixtures-content">
      <div class="loading-state"><div class="spinner"></div><p class="loading-text">Fetching fixtures...</p></div>
    </div>
  </div>

  <p class="footer-note">Data provided by football-data.org · Live 2025/26 season</p>

  <script>
    const LEAGUES = {
      'PL':  { name: 'Premier League', totalMatchdays: 38 },
      'PD':  { name: 'La Liga',        totalMatchdays: 38 },
      'BL1': { name: 'Bundesliga',     totalMatchdays: 34 },
      'SA':  { name: 'Serie A',        totalMatchdays: 38 },
      'FL1': { name: 'Ligue 1',        totalMatchdays: 34 }
    };

    let currentLeague = 'PL';
    let currentMatchday = null;
    let maxMatchday = 38;
    let fetching = false;
    const cache = {};

    function setStatus(type, text) {
      const el = document.getElementById('status-pill');
      el.className = 'status-pill ' + type;
      el.textContent = text;
    }

    function setButtons(disabled) {
      document.querySelectorAll('.league-btn').forEach(b => b.disabled = disabled);
      document.getElementById('btn-prev').disabled = disabled || currentMatchday <= 1;
      document.getElementById('btn-next').disabled = disabled || currentMatchday >= maxMatchday;
    }

    function formatDate(dateStr) {
      const d = new Date(dateStr);
      return d.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'long' });
    }

    function formatTime(dateStr) {
      const d = new Date(dateStr);
      return d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' });
    }

    function getStatusInfo(status) {
      switch(status) {
        case 'LIVE':
        case 'IN_PLAY':
        case 'PAUSED':
          return { cls: 'ms-live', label: 'LIVE' };
        case 'FINISHED':
          return { cls: 'ms-finished', label: 'FT' };
        case 'TIMED':
        case 'SCHEDULED':
          return { cls: 'ms-scheduled', label: 'UP' };
        case 'POSTPONED':
          return { cls: 'ms-postponed', label: 'PPD' };
        case 'CANCELLED':
          return { cls: 'ms-postponed', label: 'CXL' };
        default:
          return { cls: 'ms-scheduled', label: status };
      }
    }

    function isLive(status) {
      return ['LIVE','IN_PLAY','PAUSED'].includes(status);
    }

    function isFinished(status) {
      return status === 'FINISHED';
    }

    function getWinner(match) {
      const h = match.score?.fullTime?.home;
      const a = match.score?.fullTime?.away;
      if (h == null || a == null) return null;
      if (h > a) return 'home';
      if (a > h) return 'away';
      return 'draw';
    }

    async function loadFixtures(league, matchday) {
      if (fetching) return;
      fetching = true;
      setButtons(true);

      currentLeague = league;
      const leagueInfo = LEAGUES[league];
      maxMatchday = leagueInfo.totalMatchdays;

      document.querySelectorAll('.league-btn').forEach(b => b.classList.toggle('active', b.dataset.league === league));

      const content = document.getElementById('fixtures-content');
      const title = document.getElementById('card-title');
      const meta = document.getElementById('card-meta');
      const updateTime = document.getElementById('update-time');

      setStatus('loading', 'LOADING');
      content.innerHTML = `<div class="loading-state"><div class="spinner"></div><p class="loading-text">Fetching ${leagueInfo.name} fixtures...</p></div>`;
      title.textContent = leagueInfo.name;
      meta.textContent = '';
      updateTime.textContent = '';

      const cacheKey = `${league}-${matchday}`;

      try {
        let matches, currentMd;

        if (cache[cacheKey]) {
          matches = cache[cacheKey].matches;
          currentMd = cache[cacheKey].matchday;
          updateTime.textContent = 'Cached · ' + cache[cacheKey].time;
        } else {
          let url = `/api/matches/${league}`;
          if (matchday) url += `?matchday=${matchday}`;

          const res = await fetch(url);
          if (!res.ok) throw new Error(`Server error ${res.status}`);
          const data = await res.json();
          if (data.error) throw new Error(data.error);

          matches = data.matches || [];
          if (matches.length === 0) throw new Error('No matches found');

          // Find current matchday from response
          currentMd = matchday || data.filters?.matchday || matches[0]?.season?.currentMatchday || 1;
          currentMd = parseInt(currentMd);

          cache[cacheKey] = { matches, matchday: currentMd, time: new Date().toLocaleTimeString() };
          updateTime.textContent = 'Updated ' + new Date().toLocaleTimeString();
        }

        currentMatchday = parseInt(cache[cacheKey].matchday);
        document.getElementById('md-num').textContent = currentMatchday;

        title.textContent = `${leagueInfo.name} — Matchday ${currentMatchday}`;
        meta.textContent = `${matches.length} matches`;
        setStatus('live', 'LIVE');
        renderMatches(matches);

      } catch (err) {
        console.error(err);
        setStatus('error', 'ERROR');
        title.textContent = leagueInfo.name + ' — Unavailable';
        meta.textContent = err.message;
        content.innerHTML = `<div class="loading-state">
          <p class="loading-text" style="color:#ff6464">⚠️ ${err.message}</p>
          <p class="loading-text" style="margin-top:8px;font-size:12px">Rate limit: wait 60 seconds and try again</p>
        </div>`;
      } finally {
        setButtons(false);
        fetching = false;
      }
    }

    function renderMatches(matches) {
      const content = document.getElementById('fixtures-content');

      // Group by date
      const groups = {};
      matches.forEach(m => {
        const dateKey = formatDate(m.utcDate);
        if (!groups[dateKey]) groups[dateKey] = [];
        groups[dateKey].push(m);
      });

      if (Object.keys(groups).length === 0) {
        content.innerHTML = `<div class="empty-state">No matches found for this matchday</div>`;
        return;
      }

      let html = '';
      Object.entries(groups).forEach(([date, dayMatches]) => {
        html += `<div class="date-group"><div class="date-label">${date}</div>`;
        dayMatches.forEach(match => {
          const statusInfo = getStatusInfo(match.status);
          const live = isLive(match.status);
          const finished = isFinished(match.status);
          const winner = getWinner(match);

          const homeScore = match.score?.fullTime?.home;
          const awayScore = match.score?.fullTime?.away;
          const htHome = match.score?.halfTime?.home;
          const htAway = match.score?.halfTime?.away;

          const homeCrest = match.homeTeam?.crest ? `/api/crest?url=${encodeURIComponent(match.homeTeam.crest)}` : '';
          const awayCrest = match.awayTeam?.crest ? `/api/crest?url=${encodeURIComponent(match.awayTeam.crest)}` : '';

          const homeWinner = winner === 'home';
          const awayWinner = winner === 'away';

          let scoreHTML = '';
          if (finished || live) {
            const scoreClass = live ? 'score-display live-score' : 'score-display';
            scoreHTML = `<div class="${scoreClass}">${homeScore ?? 0} — ${awayScore ?? 0}</div>`;
          } else {
            scoreHTML = `<div class="kickoff-time">${formatTime(match.utcDate)}</div>`;
          }

          const htHTML = (finished && htHome != null) 
            ? `<div class="ht-score">HT: ${htHome} — ${htAway}</div>` 
            : '';

          html += `
            <div class="match-card" onclick="toggleDetail('${match.id}')">
              <div class="team">
                ${homeCrest ? `<img class="team-crest" src="${homeCrest}" onerror="this.style.display='none'">` : `<span class="team-crest-placeholder"></span>`}
                <span class="team-name ${homeWinner ? 'winner' : ''}">${match.homeTeam?.shortName || match.homeTeam?.name}</span>
              </div>
              <div class="score-center">
                ${scoreHTML}
                <span class="match-status ${statusInfo.cls}">${statusInfo.label}</span>
                ${htHTML}
              </div>
              <div class="team away">
                ${awayCrest ? `<img class="team-crest" src="${awayCrest}" onerror="this.style.display='none'">` : `<span class="team-crest-placeholder"></span>`}
                <span class="team-name ${awayWinner ? 'winner' : ''}">${match.awayTeam?.shortName || match.awayTeam?.name}</span>
              </div>
            </div>
            <div class="detail-panel" id="detail-${match.id}">
              <div class="detail-grid">
                <div class="detail-item">
                  <span class="detail-label">Competition</span>
                  <span class="detail-value">${match.competition?.name || '—'}</span>
                </div>
                <div class="detail-item">
                  <span class="detail-label">Matchday</span>
                  <span class="detail-value">${match.matchday || '—'}</span>
                </div>
                <div class="detail-item">
                  <span class="detail-label">Date & Time</span>
                  <span class="detail-value">${formatDate(match.utcDate)} · ${formatTime(match.utcDate)}</span>
                </div>
                <div class="detail-item">
                  <span class="detail-label">Venue</span>
                  <span class="detail-value">${match.venue || '—'}</span>
                </div>
                <div class="detail-item">
                  <span class="detail-label">Referee</span>
                  <span class="detail-value">${match.referees?.[0]?.name || '—'}</span>
                </div>
                ${finished ? `
                <div class="detail-item">
                  <span class="detail-label">Full Time</span>
                  <span class="detail-value" style="color:var(--gold);font-size:16px;font-family:'Bebas Neue',sans-serif;letter-spacing:2px">${homeScore} — ${awayScore}</span>
                </div>
                ${htHome != null ? `
                <div class="detail-item">
                  <span class="detail-label">Half Time</span>
                  <span class="detail-value">${htHome} — ${htAway}</span>
                </div>` : ''}
                ` : ''}
              </div>
            </div>`;
        });
        html += `</div>`;
      });

      content.innerHTML = html;
    }

    function toggleDetail(matchId) {
      const panel = document.getElementById(`detail-${matchId}`);
      if (!panel) return;
      const isOpen = panel.classList.contains('open');
      // Close all panels
      document.querySelectorAll('.detail-panel').forEach(p => p.classList.remove('open'));
      // Open this one if it was closed
      if (!isOpen) panel.classList.add('open');
    }

    // League buttons
    document.querySelectorAll('.league-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        currentMatchday = null;
        loadFixtures(btn.dataset.league, null);
      });
    });

    // Matchday nav
    document.getElementById('btn-prev').addEventListener('click', () => {
      if (currentMatchday > 1) loadFixtures(currentLeague, currentMatchday - 1);
    });
    document.getElementById('btn-next').addEventListener('click', () => {
      if (currentMatchday < maxMatchday) loadFixtures(currentLeague, currentMatchday + 1);
    });

    // Initial load
    document.addEventListener('DOMContentLoaded', () => loadFixtures('PL', null));
  </script>
  <script src="/javascripts/chatbot.js"></script>
<script src="/javascripts/polish.js"></script>
</body>
</html>
