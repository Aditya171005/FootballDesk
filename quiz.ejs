<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Football Quiz | Football Hub</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: #0a0e17; color: white; min-height: 100vh; }

    /* NAV */
    header {
      background: rgba(8,12,20,0.95); backdrop-filter: blur(12px);
      padding: 0 40px; display: flex; justify-content: space-between; align-items: center;
      position: fixed; top:0; left:0; right:0; z-index: 200; height: 70px;
      border-bottom: 1px solid rgba(255,215,0,0.1);
    }
    .logo { height: 50px; width: auto; }
    nav ul { display:flex; gap:4px; list-style:none; padding:0; margin:0; align-items:center; }
    nav a { color:rgba(255,255,255,0.7); text-decoration:none; font-weight:600; font-size:13px; padding:7px 13px; border-radius:8px; transition:all 0.2s; }
    nav a:hover { color:#FFD700; background:rgba(255,215,0,0.08); }
    nav a.login-btn { background:#f70404; color:white; border-radius:20px; padding:7px 18px; }
    nav a.active { color:#FFD700; }

    /* MORE DROPDOWN */
    .nav-more { position:relative; }
    .nav-more-btn { color:rgba(255,255,255,0.7); background:none; border:none; font-weight:600; font-size:13px; padding:7px 13px; border-radius:8px; cursor:pointer; font-family:'DM Sans',sans-serif; transition:all 0.2s; display:flex; align-items:center; gap:4px; }
    .nav-more-btn:hover { color:#FFD700; background:rgba(255,215,0,0.08); }
    .nav-more-btn .arrow { font-size:10px; transition:transform 0.2s; }
    .nav-more.open .nav-more-btn .arrow { transform:rotate(180deg); }
    .more-dropdown { display:none; position:absolute; top:calc(100% + 8px); right:0; background:#0f1623; border:1px solid rgba(255,215,0,0.2); border-radius:14px; overflow:hidden; z-index:999; box-shadow:0 20px 60px rgba(0,0,0,0.7); min-width:200px; }
    .nav-more.open .more-dropdown { display:block; }
    .more-dropdown a { display:flex; align-items:center; gap:10px; padding:11px 16px; color:rgba(255,255,255,0.8); text-decoration:none; font-size:13px; font-weight:600; transition:all 0.15s; border-bottom:1px solid rgba(255,255,255,0.04); }
    .more-dropdown a:last-child { border-bottom:none; }
    .more-dropdown a:hover { background:rgba(255,215,0,0.07); color:#FFD700; }

    /* PAGE */
    .page { padding: 100px 20px 60px; max-width: 800px; margin: 0 auto; }

    .page-header { text-align:center; margin-bottom:40px; }
    .page-header h1 { font-family:'Bebas Neue',sans-serif; font-size:56px; letter-spacing:3px; color:white; line-height:1; }
    .page-header h1 span { color:#FFD700; }
    .page-header p { color:rgba(255,255,255,0.5); margin-top:8px; font-size:16px; }

    /* SETUP SCREEN */
    #setup-screen { animation: fadeIn 0.4s ease; }
    @keyframes fadeIn { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }

    .setup-card { background:#0f1623; border-radius:20px; border:1px solid rgba(255,215,0,0.12); padding:36px; }
    .setup-label { font-size:13px; font-weight:700; color:rgba(255,255,255,0.5); text-transform:uppercase; letter-spacing:1px; margin-bottom:12px; }
    .option-grid { display:grid; gap:10px; margin-bottom:28px; }
    .option-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .option-grid.cols-5 { grid-template-columns: repeat(5, 1fr); }
    .opt-btn {
      background:#141d2e; border:2px solid rgba(255,255,255,0.08); border-radius:12px;
      color:rgba(255,255,255,0.7); font-size:13px; font-weight:600; padding:12px 8px;
      cursor:pointer; transition:all 0.2s; font-family:'DM Sans',sans-serif; text-align:center;
    }
    .opt-btn:hover { border-color:rgba(255,215,0,0.3); color:#FFD700; background:rgba(255,215,0,0.05); }
    .opt-btn.selected { border-color:#FFD700; background:rgba(255,215,0,0.1); color:#FFD700; }

    .start-btn {
      width:100%; padding:16px; background:linear-gradient(135deg, #FFD700, #FFA500);
      border:none; border-radius:14px; color:#000; font-size:16px; font-weight:700;
      font-family:'DM Sans',sans-serif; cursor:pointer; transition:all 0.2s;
    }
    .start-btn:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(255,215,0,0.3); }
    .start-btn:disabled { opacity:0.5; cursor:not-allowed; transform:none; }

    /* LOADING */
    #loading-screen { display:none; text-align:center; padding:80px 0; animation: fadeIn 0.3s ease; }
    .spinner { width:56px; height:56px; border:3px solid rgba(255,215,0,0.15); border-top-color:#FFD700; border-radius:50%; animation:spin 0.9s linear infinite; margin:0 auto 20px; }
    @keyframes spin { to{transform:rotate(360deg)} }
    .loading-text { color:rgba(255,255,255,0.6); font-size:15px; }

    /* QUIZ SCREEN */
    #quiz-screen { display:none; animation: fadeIn 0.4s ease; }

    .progress-wrap { margin-bottom:24px; }
    .progress-info { display:flex; justify-content:space-between; font-size:13px; color:rgba(255,255,255,0.5); margin-bottom:8px; }
    .progress-bar { height:4px; background:rgba(255,255,255,0.08); border-radius:2px; overflow:hidden; }
    .progress-fill { height:100%; background:linear-gradient(90deg, #FFD700, #FFA500); border-radius:2px; transition:width 0.4s ease; }

    .timer-wrap { display:flex; justify-content:center; margin-bottom:20px; }
    .timer {
      font-family:'Bebas Neue',sans-serif; font-size:32px; letter-spacing:2px;
      color:#FFD700; background:#0f1623; border:2px solid rgba(255,215,0,0.2);
      border-radius:12px; padding:6px 20px; min-width:80px; text-align:center;
      transition:color 0.3s;
    }
    .timer.urgent { color:#ff4444; border-color:rgba(255,68,68,0.4); animation:pulse-timer 0.5s infinite; }
    @keyframes pulse-timer { 0%,100%{opacity:1} 50%{opacity:0.6} }

    .question-card { background:#0f1623; border-radius:20px; border:1px solid rgba(255,255,255,0.08); padding:32px; margin-bottom:20px; }
    .q-number { font-size:12px; font-weight:700; color:rgba(255,215,0,0.6); text-transform:uppercase; letter-spacing:1px; margin-bottom:12px; }
    .q-text { font-size:18px; font-weight:700; line-height:1.5; color:white; }

    .options-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
    .option-card {
      background:#141d2e; border:2px solid rgba(255,255,255,0.07); border-radius:14px;
      padding:16px 18px; cursor:pointer; transition:all 0.2s; font-size:14px; font-weight:600;
      color:rgba(255,255,255,0.8); display:flex; align-items:center; gap:10px;
      font-family:'DM Sans',sans-serif; text-align:left;
    }
    .option-card:hover:not(.locked) { border-color:rgba(255,215,0,0.3); color:#FFD700; background:rgba(255,215,0,0.05); }
    .option-card .opt-letter { font-family:'Bebas Neue',sans-serif; font-size:18px; color:rgba(255,255,255,0.3); min-width:20px; }
    .option-card.correct { border-color:#00cc66; background:rgba(0,204,102,0.12); color:#00cc66; }
    .option-card.correct .opt-letter { color:#00cc66; }
    .option-card.wrong { border-color:#ff4444; background:rgba(255,68,68,0.12); color:#ff4444; }
    .option-card.wrong .opt-letter { color:#ff4444; }
    .option-card.locked { cursor:default; }

    .explanation {
      background:#141d2e; border-left:3px solid #FFD700; border-radius:0 12px 12px 0;
      padding:14px 16px; font-size:13px; color:rgba(255,255,255,0.7); line-height:1.6;
      display:none; margin-top:12px; animation:fadeIn 0.3s ease;
    }

    .next-btn {
      width:100%; padding:14px; background:linear-gradient(135deg, #1a56ff, #0a2aaa);
      border:none; border-radius:12px; color:white; font-size:15px; font-weight:700;
      font-family:'DM Sans',sans-serif; cursor:pointer; transition:all 0.2s; display:none; margin-top:16px;
    }
    .next-btn:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(26,86,255,0.4); }

    /* RESULTS */
    #results-screen { display:none; text-align:center; animation:fadeIn 0.5s ease; }
    .score-circle {
      width:160px; height:160px; border-radius:50%; margin:0 auto 24px;
      border:4px solid #FFD700; display:flex; flex-direction:column;
      align-items:center; justify-content:center; background:#0f1623;
      box-shadow:0 0 40px rgba(255,215,0,0.2);
    }
    .score-num { font-family:'Bebas Neue',sans-serif; font-size:56px; color:#FFD700; line-height:1; }
    .score-denom { font-size:14px; color:rgba(255,255,255,0.4); }
    .results-title { font-family:'Bebas Neue',sans-serif; font-size:36px; color:white; margin-bottom:8px; }
    .results-sub { color:rgba(255,255,255,0.5); font-size:15px; margin-bottom:32px; }

    .results-breakdown { background:#0f1623; border-radius:16px; border:1px solid rgba(255,255,255,0.08); padding:24px; margin-bottom:24px; text-align:left; }
    .breakdown-item { display:flex; align-items:center; justify-content:space-between; padding:10px 0; border-bottom:1px solid rgba(255,255,255,0.05); font-size:14px; }
    .breakdown-item:last-child { border-bottom:none; }
    .breakdown-q { color:rgba(255,255,255,0.7); flex:1; margin-right:12px; }
    .breakdown-result { font-weight:700; font-size:13px; }
    .breakdown-result.c { color:#00cc66; }
    .breakdown-result.w { color:#ff4444; }

    .results-actions { display:flex; gap:12px; justify-content:center; flex-wrap:wrap; }
    .res-btn {
      padding:13px 28px; border-radius:30px; font-size:14px; font-weight:700;
      font-family:'DM Sans',sans-serif; cursor:pointer; transition:all 0.2s; text-decoration:none;
    }
    .res-btn-gold { background:linear-gradient(135deg,#FFD700,#FFA500); color:#000; border:none; }
    .res-btn-gold:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(255,215,0,0.3); }
    .res-btn-outline { background:transparent; border:2px solid rgba(255,255,255,0.15); color:rgba(255,255,255,0.7); }
    .res-btn-outline:hover { border-color:rgba(255,255,255,0.3); color:white; }

    footer { background:#080c14; border-top:1px solid rgba(255,215,0,0.08); text-align:center; padding:24px; font-size:13px; color:rgba(255,255,255,0.3); margin-top:60px; }

    @media (max-width:600px) {
      .options-grid { grid-template-columns:1fr; }
      .option-grid.cols-3 { grid-template-columns:1fr 1fr; }
      .option-grid.cols-5 { grid-template-columns:1fr 1fr; }
    }
  </style>
</head>
<body>

  <header>
    <img src="/images/logo2.jpg" alt="Logo" class="logo">
    <nav>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/standings">🏆 Standings</a></li>
        <li><a href="/fixtures">📅 Fixtures</a></li>
        <li><a href="/scorers">⚽ Scorers</a></li>
        <li><a href="/champions-league">🏆 UCL</a></li>
        <li class="nav-more" id="nav-more">
          <button class="nav-more-btn" onclick="toggleMore()">More <span class="arrow">▾</span></button>
          <div class="more-dropdown">
            <a href="/quiz" style="color:#FFD700;">🧠 Football Quiz</a>
            <a href="/compare">⚖️ Player Compare</a>
            <a href="/history">🏅 League History</a>
            <a href="/today">📅 Today's Matches</a>
            <a href="/news">📰 News</a>
          </div>
        </li>
        <li><a href="/loginpage" class="login-btn">Login</a></li>
      </ul>
    </nav>
  </header>

  <div class="page">
    <div class="page-header">
      <h1>Football <span>Quiz</span></h1>
      <p>Test your knowledge — AI-generated questions, new every time</p>
    </div>

    <!-- SETUP -->
    <div id="setup-screen">
      <div class="setup-card">
        <div class="setup-label">Choose Category</div>
        <div class="option-grid cols-5" id="cat-grid">
          <button class="opt-btn selected" data-cat="Mixed">🔀 Mixed</button>
          <button class="opt-btn" data-cat="History">📜 History</button>
          <button class="opt-btn" data-cat="Current Season">📊 Current</button>
          <button class="opt-btn" data-cat="Players">👟 Players</button>
          <button class="opt-btn" data-cat="World Cup">🌍 World Cup</button>
        </div>

        <div class="setup-label">Difficulty</div>
        <div class="option-grid cols-3" id="diff-grid">
          <button class="opt-btn" data-diff="Easy">🟢 Easy</button>
          <button class="opt-btn selected" data-diff="Medium">🟡 Medium</button>
          <button class="opt-btn" data-diff="Hard">🔴 Hard</button>
        </div>

        <button class="start-btn" id="start-btn" onclick="startQuiz()">Generate Quiz ⚡</button>
      </div>
    </div>

    <!-- LOADING -->
    <div id="loading-screen">
      <div class="spinner"></div>
      <p class="loading-text">AI is generating your questions...</p>
    </div>

    <!-- QUIZ -->
    <div id="quiz-screen">
      <div class="progress-wrap">
        <div class="progress-info">
          <span id="q-counter">Question 1 of 10</span>
          <span id="score-display">Score: 0</span>
        </div>
        <div class="progress-bar"><div class="progress-fill" id="progress-fill" style="width:10%"></div></div>
      </div>

      <div class="timer-wrap">
        <div class="timer" id="timer">30</div>
      </div>

      <div class="question-card">
        <div class="q-number" id="q-number">Question 1</div>
        <div class="q-text" id="q-text"></div>
      </div>

      <div class="options-grid" id="options-grid"></div>
      <div class="explanation" id="explanation"></div>
      <button class="next-btn" id="next-btn" onclick="nextQuestion()">Next Question →</button>
    </div>

    <!-- RESULTS -->
    <div id="results-screen">
      <div class="score-circle">
        <div class="score-num" id="final-score">0</div>
        <div class="score-denom">/ 10</div>
      </div>
      <div class="results-title" id="results-title">Well Done!</div>
      <div class="results-sub" id="results-sub"></div>
      <div class="results-breakdown" id="results-breakdown"></div>
      <div class="results-actions">
        <button class="res-btn res-btn-gold" onclick="resetQuiz()">Play Again 🔄</button>
        <a href="/" class="res-btn res-btn-outline">← Back Home</a>
      </div>
    </div>
  </div>

  <footer><p>&copy; 2026 Football World. All rights reserved.</p></footer>

  <script>
    // ── MORE DROPDOWN ──
    function toggleMore() { document.getElementById('nav-more').classList.toggle('open'); }
    document.addEventListener('click', (e) => { if (!e.target.closest('#nav-more')) document.getElementById('nav-more').classList.remove('open'); });

    // ── STATE ──
    let selectedCat = 'Mixed';
    let selectedDiff = 'Medium';
    let questions = [];
    let currentQ = 0;
    let score = 0;
    let userAnswers = [];
    let timerInterval = null;
    let timeLeft = 30;
    let answered = false;

    // ── SETUP SELECTION ──
    document.querySelectorAll('[data-cat]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-cat]').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        selectedCat = btn.dataset.cat;
      });
    });
    document.querySelectorAll('[data-diff]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-diff]').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
        selectedDiff = btn.dataset.diff;
      });
    });

    // ── START ──
    async function startQuiz() {
      document.getElementById('setup-screen').style.display = 'none';
      document.getElementById('loading-screen').style.display = 'block';

      try {
        const res = await fetch('/api/quiz', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ category: selectedCat, difficulty: selectedDiff })
        });
        const data = await res.json();
        if (!data.questions || data.questions.length === 0) throw new Error('No questions');
        questions = data.questions;
        score = 0;
        currentQ = 0;
        userAnswers = [];
        document.getElementById('loading-screen').style.display = 'none';
        document.getElementById('quiz-screen').style.display = 'block';
        renderQuestion();
      } catch(e) {
        document.getElementById('loading-screen').style.display = 'none';
        document.getElementById('setup-screen').style.display = 'block';
        alert('Failed to load questions. Please try again.');
      }
    }

    // ── RENDER QUESTION ──
    function renderQuestion() {
      const q = questions[currentQ];
      answered = false;

      document.getElementById('q-counter').textContent = `Question ${currentQ + 1} of ${questions.length}`;
      document.getElementById('score-display').textContent = `Score: ${score}`;
      document.getElementById('progress-fill').style.width = `${((currentQ + 1) / questions.length) * 100}%`;
      document.getElementById('q-number').textContent = `Question ${currentQ + 1}`;
      document.getElementById('q-text').textContent = q.question;
      document.getElementById('explanation').style.display = 'none';
      document.getElementById('next-btn').style.display = 'none';

      const letters = ['A', 'B', 'C', 'D'];
      const grid = document.getElementById('options-grid');
      grid.innerHTML = q.options.map((opt, i) => `
        <button class="option-card" onclick="selectAnswer(${i})">
          <span class="opt-letter">${letters[i]}</span>
          <span>${opt}</span>
        </button>
      `).join('');

      startTimer();
    }

    // ── TIMER ──
    function startTimer() {
      clearInterval(timerInterval);
      timeLeft = 30;
      const timerEl = document.getElementById('timer');
      timerEl.textContent = timeLeft;
      timerEl.classList.remove('urgent');

      timerInterval = setInterval(() => {
        timeLeft--;
        timerEl.textContent = timeLeft;
        if (timeLeft <= 10) timerEl.classList.add('urgent');
        if (timeLeft <= 0) {
          clearInterval(timerInterval);
          if (!answered) timeOut();
        }
      }, 1000);
    }

    function timeOut() {
      answered = true;
      userAnswers.push({ qIdx: currentQ, chosen: -1, correct: false });
      revealAnswer(-1);
    }

    // ── ANSWER ──
    function selectAnswer(idx) {
      if (answered) return;
      answered = true;
      clearInterval(timerInterval);
      const q = questions[currentQ];
      const isCorrect = idx === q.correct;
      if (isCorrect) score++;
      userAnswers.push({ qIdx: currentQ, chosen: idx, correct: isCorrect });
      revealAnswer(idx);
    }

    function revealAnswer(chosen) {
      const q = questions[currentQ];
      const cards = document.querySelectorAll('.option-card');
      cards.forEach((card, i) => {
        card.classList.add('locked');
        if (i === q.correct) card.classList.add('correct');
        else if (i === chosen && chosen !== q.correct) card.classList.add('wrong');
      });

      if (q.explanation) {
        const expEl = document.getElementById('explanation');
        expEl.textContent = '💡 ' + q.explanation;
        expEl.style.display = 'block';
      }

      document.getElementById('score-display').textContent = `Score: ${score}`;
      document.getElementById('next-btn').textContent = currentQ < questions.length - 1 ? 'Next Question →' : 'See Results 🏆';
      document.getElementById('next-btn').style.display = 'block';
    }

    // ── NEXT ──
    function nextQuestion() {
      currentQ++;
      if (currentQ >= questions.length) showResults();
      else renderQuestion();
    }

    // ── RESULTS ──
    function showResults() {
      document.getElementById('quiz-screen').style.display = 'none';
      document.getElementById('results-screen').style.display = 'block';

      const pct = (score / questions.length) * 100;
      document.getElementById('final-score').textContent = score;

      let title, sub;
      if (pct >= 90) { title = '🏆 Legend!'; sub = 'You\'re a football genius. Absolute class.'; }
      else if (pct >= 70) { title = '⚽ Great Job!'; sub = 'Solid football knowledge. You know your stuff.'; }
      else if (pct >= 50) { title = '📊 Not Bad!'; sub = 'Room to improve — keep watching the game!'; }
      else { title = '😅 Keep Trying!'; sub = 'Football is a learning curve. Play again!'; }

      document.getElementById('results-title').textContent = title;
      document.getElementById('results-sub').textContent = sub;

      const breakdown = userAnswers.map(a => {
        const q = questions[a.qIdx];
        const resultText = a.chosen === -1 ? '⏱ Time Out' : a.correct ? '✓ Correct' : '✗ Wrong';
        const cls = a.correct ? 'c' : 'w';
        return `<div class="breakdown-item"><span class="breakdown-q">${q.question.substring(0,60)}${q.question.length > 60 ? '...' : ''}</span><span class="breakdown-result ${cls}">${resultText}</span></div>`;
      }).join('');
      document.getElementById('results-breakdown').innerHTML = breakdown;
    }

    // ── RESET ──
    function resetQuiz() {
      document.getElementById('results-screen').style.display = 'none';
      document.getElementById('setup-screen').style.display = 'block';
    }
  </script>
  <script src="/javascripts/chatbot.js"></script>
</body>
</html>
