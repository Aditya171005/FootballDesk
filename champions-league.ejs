<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>UEFA Champions League — Football Hub</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --blue: #1a56ff; --blue2: #4f7cff; --blue-glow: rgba(26,86,255,0.25);
      --gold: #FFD700; --gold2: #FFA500;
      --bg: #060a12; --card: #0c1220; --card2: #111827;
      --border: rgba(26,86,255,0.18); --text: #e8eaf0;
      --muted: rgba(255,255,255,0.4);
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg); color: var(--text);
      font-family: 'DM Sans', sans-serif; min-height: 100vh;
      background-image:
        radial-gradient(ellipse 60% 40% at 80% 0%, rgba(26,86,255,0.1) 0%, transparent 60%),
        radial-gradient(ellipse 40% 30% at 0% 80%, rgba(26,86,255,0.07) 0%, transparent 50%);
    }

    /* NAV */
    .topnav {
      background: rgba(6,10,18,0.96); backdrop-filter: blur(12px);
      padding: 0 40px; display: flex; justify-content: space-between; align-items: center;
      position: sticky; top: 0; z-index: 100; height: 64px;
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Bebas Neue', sans-serif; font-size: 22px; letter-spacing: 3px;
      color: white; text-decoration: none; display: flex; align-items: center; gap: 10px;
    }
    .nav-logo span { color: var(--blue2); }
    .nav-links { display: flex; gap: 6px; }
    .nav-link {
      color: var(--muted); text-decoration: none; font-weight: 600; font-size: 13px;
      padding: 7px 14px; border-radius: 8px; transition: all 0.2s;
    }
    .nav-link:hover { color: white; background: rgba(255,255,255,0.06); }
    .nav-link.active { color: var(--blue2); background: rgba(26,86,255,0.1); }

    /* HERO */
    .ucl-hero {
      padding: 60px 40px 40px;
      max-width: 1200px; margin: 0 auto;
      display: flex; align-items: center; gap: 32px;
    }
   .ucl-ball {
      width: 110px; height: 110px; flex-shrink: 0;
      object-fit: contain;
      filter: brightness(1.3) contrast(1.1) drop-shadow(0 0 12px rgba(255,255,255,0.6)) drop-shadow(0 0 30px rgba(255,255,255,0.3));
      animation: pulse-ball 3s ease-in-out infinite;
    }
    @keyframes pulse-ball {
      0%, 100% { filter: brightness(1.3) contrast(1.1) drop-shadow(0 0 12px rgba(255,255,255,0.6)) drop-shadow(0 0 30px rgba(255,255,255,0.3)); }
      50% { filter: brightness(1.5) contrast(1.2) drop-shadow(0 0 20px rgba(255,255,255,0.9)) drop-shadow(0 0 50px rgba(200,220,255,0.5)); }
    }
    .ucl-hero-text { flex: 1; }
    .ucl-tag {
      display: inline-block; padding: 4px 14px; border-radius: 20px;
      background: rgba(26,86,255,0.15); border: 1px solid rgba(26,86,255,0.3);
      font-size: 11px; font-weight: 700; letter-spacing: 2px; color: var(--blue2);
      text-transform: uppercase; margin-bottom: 12px;
    }
    .ucl-title {
      font-family: 'Bebas Neue', sans-serif; font-size: 64px; line-height: 1;
      letter-spacing: 3px; color: white; margin-bottom: 8px;
    }
    .ucl-title span { color: var(--blue2); }
    .ucl-sub { font-size: 15px; color: var(--muted); }

    /* TABS */
    .tabs-wrap { max-width: 1200px; margin: 0 auto; padding: 0 40px 32px; }
    .tabs {
      display: flex; gap: 6px;
      background: var(--card); border-radius: 14px; padding: 6px;
      border: 1px solid var(--border); width: fit-content;
    }
    .tab-btn {
      padding: 10px 24px; border-radius: 10px; border: none;
      font-family: 'DM Sans', sans-serif; font-weight: 700; font-size: 14px;
      cursor: pointer; transition: all 0.2s; color: var(--muted); background: transparent;
    }
    .tab-btn.active {
      background: linear-gradient(135deg, var(--blue), #0a2aaa);
      color: white; box-shadow: 0 4px 20px var(--blue-glow);
    }
    .tab-btn:hover:not(.active) { color: white; background: rgba(255,255,255,0.05); }

    /* CONTENT */
    .content-wrap { max-width: 1200px; margin: 0 auto; padding: 0 40px 60px; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* STANDINGS TABLE */
    .standings-card {
      background: var(--card); border-radius: 16px;
      border: 1px solid var(--border); overflow: hidden;
    }
    .standings-head {
      padding: 18px 24px; border-bottom: 1px solid rgba(255,255,255,0.05);
      background: rgba(26,86,255,0.05);
      font-family: 'Bebas Neue', sans-serif; font-size: 20px;
      letter-spacing: 1px; color: var(--blue2);
      display: flex; align-items: center; gap: 10px;
    }
    .standings-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
    .standings-table th {
      padding: 12px 16px; text-align: center; font-size: 11px; font-weight: 700;
      letter-spacing: 1.5px; text-transform: uppercase; color: rgba(26,86,255,0.7);
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .standings-table th:nth-child(1) { width: 44px; }
    .standings-table th:nth-child(2) { text-align: left; width: auto; }
    .standings-table th:nth-child(n+3) { width: 52px; }
    .standings-table td {
      padding: 13px 16px; text-align: center; font-size: 14px; font-weight: 600;
      border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .standings-table td:nth-child(2) { text-align: left; }
    .standings-table tr:last-child td { border-bottom: none; }
    .standings-table tr:hover td { background: rgba(26,86,255,0.04); }
    .pos-num { font-family: 'Bebas Neue', sans-serif; font-size: 18px; color: var(--muted); }
    .pos-num.qualify { color: var(--blue2); }
    .pos-num.knockout { color: var(--gold); }
    .team-cell { display: flex; align-items: center; gap: 10px; }
    .team-crest-sm { width: 24px; height: 24px; object-fit: contain; }
    .team-name-cell { font-weight: 700; font-size: 14px; }
    .pts-cell { font-family: 'Bebas Neue', sans-serif; font-size: 20px; color: var(--blue2); }

    /* FIXTURES */
    .fixtures-grid { display: flex; flex-direction: column; gap: 10px; }
    .matchday-label {
      font-family: 'Bebas Neue', sans-serif; font-size: 16px; letter-spacing: 2px;
      color: var(--blue2); padding: 12px 0 4px; border-bottom: 1px solid var(--border);
      margin-bottom: 4px;
    }
    .fixture-card {
      background: var(--card); border-radius: 14px; border: 1px solid var(--border);
      padding: 16px 20px; display: grid; grid-template-columns: 1fr auto 1fr;
      align-items: center; gap: 16px; transition: border-color 0.2s;
    }
    .fixture-card:hover { border-color: rgba(26,86,255,0.4); }
    .fix-team { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 14px; }
    .fix-team.right { justify-content: flex-end; text-align: right; }
    .fix-crest { width: 28px; height: 28px; object-fit: contain; }
    .fix-center { text-align: center; display: flex; flex-direction: column; gap: 4px; align-items: center; }
    .fix-score {
      font-family: 'Bebas Neue', sans-serif; font-size: 26px;
      letter-spacing: 3px; color: white;
    }
    .fix-score.upcoming { font-size: 14px; color: var(--muted); font-family: 'DM Sans', sans-serif; }
    .fix-badge {
      padding: 3px 10px; border-radius: 10px; font-size: 10px;
      font-weight: 700; text-transform: uppercase;
    }
    .badge-FT { background: rgba(255,255,255,0.05); color: var(--muted); border: 1px solid rgba(255,255,255,0.1); }
    .badge-LIVE { background: rgba(0,255,135,0.1); color: #00ff87; border: 1px solid rgba(0,255,135,0.3); animation: livepulse 1.5s infinite; }
    .badge-UP { background: rgba(26,86,255,0.1); color: var(--blue2); border: 1px solid rgba(26,86,255,0.3); }
    @keyframes livepulse { 0%,100%{opacity:1} 50%{opacity:0.6} }

    /* SCORERS */
    .scorers-list { display: flex; flex-direction: column; gap: 10px; }
    .scorer-card {
      background: var(--card); border-radius: 14px; border: 1px solid var(--border);
      padding: 16px 20px; display: flex; align-items: center; gap: 16px;
      transition: border-color 0.2s;
    }
    .scorer-card:hover { border-color: rgba(26,86,255,0.4); }
    .scorer-rank {
      font-family: 'Bebas Neue', sans-serif; font-size: 28px;
      color: var(--muted); min-width: 36px; text-align: center;
    }
    .scorer-rank.top { color: var(--gold); }
    .scorer-info { flex: 1; }
    .scorer-name { font-weight: 700; font-size: 16px; color: white; margin-bottom: 3px; }
    .scorer-team { font-size: 12px; color: var(--muted); display: flex; align-items: center; gap: 6px; }
    .scorer-crest { width: 16px; height: 16px; object-fit: contain; }
    .scorer-stats { display: flex; gap: 20px; align-items: center; }
    .scorer-stat { text-align: center; }
    .scorer-stat-num { font-family: 'Bebas Neue', sans-serif; font-size: 28px; color: var(--blue2); line-height: 1; }
    .scorer-stat-num.gold { color: var(--gold); }
    .scorer-stat-label { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px; }
    .goals-bar-wrap { flex: 1; max-width: 120px; }
    .goals-bar-bg { background: rgba(26,86,255,0.1); border-radius: 4px; height: 6px; overflow: hidden; }
    .goals-bar-fill { background: linear-gradient(90deg, var(--blue), var(--blue2)); height: 100%; border-radius: 4px; }

    /* LOADING */
    .loading-box { display: flex; flex-direction: column; align-items: center; padding: 60px; gap: 16px; }
    .spinner { width: 40px; height: 40px; border: 3px solid rgba(26,86,255,0.15); border-top-color: var(--blue2); border-radius: 50%; animation: spin 0.8s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-text { font-size: 13px; color: var(--muted); }
    .error-box { padding: 40px; text-align: center; color: #ff6464; font-size: 14px; }

    @media (max-width: 768px) {
      .topnav { padding: 0 16px; }
      .ucl-hero { padding: 32px 16px 24px; flex-direction: column; gap: 20px; }
      .ucl-title { font-size: 42px; }
      .tabs-wrap, .content-wrap { padding-left: 16px; padding-right: 16px; }
      .fixture-card { gap: 8px; padding: 12px; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <nav class="topnav">
    <a href="/" class="nav-logo">⚽ <span>Football</span> Hub</a>
    <div class="nav-links">
      <a href="/standings" class="nav-link">Standings</a>
      <a href="/fixtures" class="nav-link">Fixtures</a>
      <a href="/scorers" class="nav-link">Scorers</a>
      <a href="/champions-league" class="nav-link active">🏆 UCL</a>
      <a href="/" class="nav-link">← Home</a>
    </div>
  </nav>

  <!-- HERO -->
  <div class="ucl-hero">
    <img class="ucl-ball" src="/api/crest?url=https%3A%2F%2Fupload.wikimedia.org%2Fwikipedia%2Fen%2Ff%2Ff5%2FUEFA_Champions_League.svg" onerror="this.outerHTML='<div style=width:90px;height:90px;background:linear-gradient(135deg,#1a56ff,#0a2aaa);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:44px;flex-shrink:0>🏆</div>'">
    <div class="ucl-hero-text">
      <div class="ucl-tag">⭐ 2024 / 25 Season</div>
      <div class="ucl-title">UEFA <span>Champions</span> League</div>
      <div class="ucl-sub">Standings · Fixtures · Top Scorers — all in one place</div>
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs-wrap">
    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('standings')">📊 Standings</button>
      <button class="tab-btn" onclick="switchTab('fixtures')">📅 Fixtures</button>
      <button class="tab-btn" onclick="switchTab('scorers')">⚽ Top Scorers</button>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="content-wrap">

    <!-- STANDINGS TAB -->
    <div class="tab-panel active" id="tab-standings">
      <div class="standings-card">
        <div class="standings-head">🏆 League Phase Standings</div>
        <div id="standings-body">
          <div class="loading-box"><div class="spinner"></div><p class="loading-text">Loading standings...</p></div>
        </div>
      </div>
    </div>

    <!-- FIXTURES TAB -->
    <div class="tab-panel" id="tab-fixtures">
      <div id="fixtures-body">
        <div class="loading-box"><div class="spinner"></div><p class="loading-text">Loading fixtures...</p></div>
      </div>
    </div>

    <!-- SCORERS TAB -->
    <div class="tab-panel" id="tab-scorers">
      <div id="scorers-body">
        <div class="loading-box"><div class="spinner"></div><p class="loading-text">Loading top scorers...</p></div>
      </div>
    </div>

  </div>

  <script>
    let loadedTabs = { standings: false, fixtures: false, scorers: false };

    function switchTab(name) {
      document.querySelectorAll('.tab-btn').forEach((b, i) => {
        b.classList.toggle('active', ['standings','fixtures','scorers'][i] === name);
      });
      document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
      document.getElementById('tab-' + name).classList.add('active');
      if (!loadedTabs[name]) {
        loadedTabs[name] = true;
        if (name === 'fixtures') loadFixtures();
        if (name === 'scorers') loadScorers();
      }
    }

    // ── STANDINGS ──────────────────────────────────────────
    async function loadStandings() {
      try {
        const res = await fetch('/api/standings/CL');
        if (!res.ok) throw new Error('rate_limit');
        const data = await res.json();
        const table = data.standings?.find(s => s.type === 'TOTAL')?.table || [];
        if (table.length === 0) throw new Error('no_data');

        let html = `<table class="standings-table">
          <thead><tr>
            <th>#</th><th style="text-align:left">Club</th>
            <th>P</th><th>W</th><th>D</th><th>L</th>
            <th>GF</th><th>GA</th><th>GD</th><th>Pts</th>
          </tr></thead><tbody>`;

        table.forEach((e, i) => {
          const posClass = i < 8 ? 'qualify' : i < 24 ? 'knockout' : '';
          const gd = e.goalDifference >= 0 ? '+' + e.goalDifference : e.goalDifference;
          const gdColor = e.goalDifference > 0 ? '#00ff87' : e.goalDifference < 0 ? '#ff4444' : 'var(--muted)';
          const crest = e.team.crest ? `/api/crest?url=${encodeURIComponent(e.team.crest)}` : '';
          html += `<tr>
            <td><span class="pos-num ${posClass}">${e.position}</span></td>
            <td><div class="team-cell">
              ${crest ? `<img class="team-crest-sm" src="${crest}" onerror="this.style.display='none'">` : ''}
              <span class="team-name-cell">${e.team.shortName || e.team.name}</span>
            </div></td>
            <td>${e.playedGames}</td>
            <td style="color:#00ff87">${e.won}</td>
            <td style="color:var(--gold)">${e.draw}</td>
            <td style="color:#ff4444">${e.lost}</td>
            <td>${e.goalsFor}</td>
            <td>${e.goalsAgainst}</td>
            <td style="color:${gdColor}">${gd}</td>
            <td class="pts-cell">${e.points}</td>
          </tr>`;
        });

        html += `</tbody></table>
          <div style="padding:14px 24px;font-size:12px;color:var(--muted);border-top:1px solid rgba(255,255,255,0.05);display:flex;gap:20px;">
            <span><span style="color:var(--blue2);font-weight:700">Blue</span> = Round of 16 (Top 8)</span>
            <span><span style="color:var(--gold);font-weight:700">Gold</span> = Knockout playoffs (9–24)</span>
          </div>`;

        document.getElementById('standings-body').innerHTML = html;
      } catch(err) {
        document.getElementById('standings-body').innerHTML =
          `<div class="error-box">⚠️ ${err.message === 'rate_limit' ? 'Rate limited — wait 60s and refresh' : 'Could not load standings'}</div>`;
      }
    }

    // ── FIXTURES ───────────────────────────────────────────
    async function loadFixtures() {
      try {
        const res = await fetch('/api/matches/CL');
        if (!res.ok) throw new Error('rate_limit');
        const data = await res.json();
        const matches = data.matches || [];
        if (matches.length === 0) throw new Error('no_data');

        const groups = {};
        matches.forEach(m => {
          const md = m.matchday || 'Unknown';
          if (!groups[md]) groups[md] = [];
          groups[md].push(m);
        });

        let html = '<div class="fixtures-grid">';
        Object.keys(groups).sort((a,b) => a-b).forEach(md => {
          html += `<div class="matchday-label">Matchday ${md}</div>`;
          groups[md].forEach(m => {
            const finished = m.status === 'FINISHED';
            const live = ['LIVE','IN_PLAY','PAUSED'].includes(m.status);
            const homeName = m.homeTeam?.shortName || m.homeTeam?.name || '?';
            const awayName = m.awayTeam?.shortName || m.awayTeam?.name || '?';
            const homeCrest = m.homeTeam?.crest ? `/api/crest?url=${encodeURIComponent(m.homeTeam.crest)}` : '';
            const awayCrest = m.awayTeam?.crest ? `/api/crest?url=${encodeURIComponent(m.awayTeam.crest)}` : '';
            const hs = m.score?.fullTime?.home ?? 0;
            const as_ = m.score?.fullTime?.away ?? 0;
            const dateStr = new Date(m.utcDate).toLocaleDateString('en-GB', { day:'numeric', month:'short', hour:'2-digit', minute:'2-digit' });
            const badgeCls = live ? 'badge-LIVE' : finished ? 'badge-FT' : 'badge-UP';
            const badgeLabel = live ? '🔴 LIVE' : finished ? 'FT' : dateStr;

            html += `<div class="fixture-card">
              <div class="fix-team">
                ${homeCrest ? `<img class="fix-crest" src="${homeCrest}" onerror="this.style.display='none'">` : '<div style="width:28px;height:28px"></div>'}
                <span>${homeName}</span>
              </div>
              <div class="fix-center">
                ${finished || live
                  ? `<div class="fix-score">${hs} — ${as_}</div>`
                  : `<div class="fix-score upcoming">vs</div>`}
                <span class="fix-badge ${badgeCls}">${badgeLabel}</span>
              </div>
              <div class="fix-team right">
                <span>${awayName}</span>
                ${awayCrest ? `<img class="fix-crest" src="${awayCrest}" onerror="this.style.display='none'">` : '<div style="width:28px;height:28px"></div>'}
              </div>
            </div>`;
          });
        });
        html += '</div>';
        document.getElementById('fixtures-body').innerHTML = html;
      } catch(err) {
        document.getElementById('fixtures-body').innerHTML =
          `<div class="error-box">⚠️ ${err.message === 'rate_limit' ? 'Rate limited — wait 60s and refresh' : 'Could not load fixtures'}</div>`;
      }
    }

    // ── SCORERS ────────────────────────────────────────────
    async function loadScorers() {
      try {
        const res = await fetch('/api/scorers/CL');
        if (!res.ok) throw new Error('rate_limit');
        const data = await res.json();
        const scorers = data.scorers || [];
        if (scorers.length === 0) throw new Error('no_data');

        const maxGoals = scorers[0]?.goals || 1;

        let html = '<div class="scorers-list">';
        scorers.forEach((s, i) => {
          const crest = s.team?.crest ? `/api/crest?url=${encodeURIComponent(s.team.crest)}` : '';
          const barWidth = Math.round((s.goals / maxGoals) * 100);
          const rankClass = i < 3 ? 'top' : '';
          html += `<div class="scorer-card">
            <div class="scorer-rank ${rankClass}">${i + 1}</div>
            <div class="scorer-info">
              <div class="scorer-name">${s.player?.name || '—'}</div>
              <div class="scorer-team">
                ${crest ? `<img class="scorer-crest" src="${crest}" onerror="this.style.display='none'">` : ''}
                ${s.team?.shortName || s.team?.name || '—'}
              </div>
              <div style="margin-top:8px">
                <div class="goals-bar-bg"><div class="goals-bar-fill" style="width:${barWidth}%"></div></div>
              </div>
            </div>
            <div class="scorer-stats">
              <div class="scorer-stat">
                <div class="scorer-stat-num ${i < 3 ? 'gold' : ''}">${s.goals ?? 0}</div>
                <div class="scorer-stat-label">Goals</div>
              </div>
              <div class="scorer-stat">
                <div class="scorer-stat-num">${s.assists ?? 0}</div>
                <div class="scorer-stat-label">Assists</div>
              </div>
              <div class="scorer-stat">
                <div class="scorer-stat-num">${s.playedMatches ?? 0}</div>
                <div class="scorer-stat-label">Games</div>
              </div>
            </div>
          </div>`;
        });
        html += '</div>';
        document.getElementById('scorers-body').innerHTML = html;
      } catch(err) {
        document.getElementById('scorers-body').innerHTML =
          `<div class="error-box">⚠️ ${err.message === 'rate_limit' ? 'Rate limited — wait 60s and refresh' : 'Could not load scorers'}</div>`;
      }
    }

    loadStandings();
    loadedTabs.standings = true;
  </script>
<script src="/javascripts/chatbot.js"></script>
<script src="/javascripts/polish.js"></script>
</body>
</html>