<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>League Standings вЂ” Football Hub</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: #080c14; color: white; min-height: 100vh; }

    /* в”Ђв”Ђ NAVBAR в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
    header {
      background: rgba(8,12,20,0.97); backdrop-filter: blur(16px);
      padding: 0 40px; display: flex; justify-content: space-between; align-items: center;
      position: fixed; top:0; left:0; right:0; z-index: 200; height: 78px;
      border-bottom: 1px solid rgba(255,215,0,0.1);
    }
    .logo { height: 62px; width: auto; }
    nav ul { display:flex; gap:4px; list-style:none; padding:0; margin:0; align-items:center; flex-wrap:wrap; }
    nav a { color:rgba(255,255,255,0.8); text-decoration:none; font-weight:600; font-size:15px; padding:8px 14px; border-radius:8px; transition:all 0.2s; white-space:nowrap; }
    nav a:hover, nav a.active { color:#FFD700; background:rgba(255,215,0,0.08); }
    nav a.login-btn { background:#f70404; color:white; border-radius:20px; padding:8px 20px; }
    nav a.login-btn:hover { background:#ff3333; }
    .nav-more { position:relative; }
    .nav-more-btn { color:rgba(255,255,255,0.8); font-weight:600; font-size:15px; padding:8px 14px; border-radius:8px; background:none; border:none; cursor:pointer; font-family:'DM Sans',sans-serif; display:flex; align-items:center; gap:4px; transition:all 0.2s; }
    .nav-more-btn:hover { color:#FFD700; background:rgba(255,215,0,0.08); }
    .nav-more-menu { display:none; position:absolute; top:calc(100% + 8px); right:0; background:#0f1623; border:1px solid rgba(255,215,0,0.2); border-radius:14px; overflow:hidden; z-index:999; box-shadow:0 20px 60px rgba(0,0,0,0.7); min-width:200px; }
    .nav-more.open .nav-more-menu { display:block; }
    .nav-more-menu a { display:flex; align-items:center; gap:10px; padding:12px 18px; color:rgba(255,255,255,0.8); text-decoration:none; font-size:13px; font-weight:600; transition:all 0.15s; border-bottom:1px solid rgba(255,255,255,0.04); }
    .nav-more-menu a:last-child { border-bottom:none; }
    .nav-more-menu a:hover { background:rgba(255,215,0,0.08); color:#FFD700; }

    /* в”Ђв”Ђ PAGE в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
    .page { padding: 100px 20px 60px; max-width: 1100px; margin: 0 auto; }

    .page-hero { text-align: center; margin-bottom: 36px; }
    .page-hero .eyebrow { font-family:'Bebas Neue',sans-serif; font-size:16px; letter-spacing:5px; color:#FFD700; margin-bottom:10px; }
    .page-hero h1 { font-family:'Bebas Neue',sans-serif; font-size:60px; line-height:1; color:white; }
    .page-hero h1 span { color:#FFD700; }
    .page-hero p { color:rgba(255,255,255,0.45); margin-top:8px; font-size:15px; }

    /* STATUS BADGE */
    .status-wrap { text-align:center; margin-bottom:28px; }
    .status-badge { display:inline-flex; align-items:center; gap:7px; padding:7px 18px; border-radius:30px; font-size:12px; font-weight:700; letter-spacing:1px; text-transform:uppercase; }
    .status-badge.loading { background:rgba(26,86,255,0.15); border:1px solid rgba(26,86,255,0.3); color:#4f7cff; }
    .status-badge.live { background:rgba(0,200,100,0.12); border:1px solid rgba(0,200,100,0.3); color:#00c864; }
    .status-badge.error { background:rgba(255,60,60,0.1); border:1px solid rgba(255,60,60,0.25); color:#ff6464; }
    .status-dot { width:7px; height:7px; border-radius:50%; background:currentColor; animation:blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

    /* в”Ђв”Ђ LEAGUE TABS в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
    .league-tabs { display:flex; gap:10px; flex-wrap:wrap; justify-content:center; margin-bottom:32px; }
    .league-btn {
      display:flex; align-items:center; gap:10px;
      padding:11px 20px; border-radius:12px;
      background:#0f1623; border:1px solid rgba(255,255,255,0.08);
      color:rgba(255,255,255,0.65); font-size:14px; font-weight:600;
      font-family:'DM Sans',sans-serif; cursor:pointer;
      transition:all 0.2s;
    }
    .league-btn:hover { border-color:rgba(255,215,0,0.35); color:#FFD700; background:rgba(255,215,0,0.06); transform:translateY(-2px); }
    .league-btn.active { background:rgba(255,215,0,0.12); border-color:#FFD700; color:#FFD700; box-shadow:0 4px 20px rgba(255,215,0,0.12); }
    .league-btn .lb-logo { width:24px; height:24px; object-fit:contain; flex-shrink:0; }
    .league-btn .lb-flag { font-size:18px; }

    /* в”Ђв”Ђ TABLE CARD в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ */
    .table-card {
      background:#0f1623; border:1px solid rgba(255,215,0,0.1);
      border-radius:20px; overflow:hidden;
      box-shadow:0 24px 60px rgba(0,0,0,0.4);
    }
    .table-header {
      display:flex; align-items:center; gap:14px;
      padding:22px 28px; border-bottom:1px solid rgba(255,255,255,0.06);
      background:rgba(255,215,0,0.03);
    }
    .table-header img { width:38px; height:38px; object-fit:contain; }
    .table-header h2 { font-family:'Bebas Neue',sans-serif; font-size:26px; letter-spacing:1px; color:white; }

    /* TABLE */
    .standings-table { width:100%; border-collapse:collapse; }
    .standings-table thead th {
      padding:12px 14px; text-align:center;
      font-size:11px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase;
      color:rgba(255,255,255,0.35); border-bottom:1px solid rgba(255,255,255,0.07);
      background:rgba(0,0,0,0.2);
    }
    .standings-table thead th.th-team { text-align:left; padding-left:18px; }
    .standings-table tbody tr {
      border-bottom:1px solid rgba(255,255,255,0.04);
      transition:background 0.15s, transform 0.15s;
      cursor:pointer;
    }
    .standings-table tbody tr:hover { background:rgba(255,215,0,0.05); }
    .standings-table tbody tr:last-child { border-bottom:none; }
    .standings-table td { padding:13px 14px; text-align:center; font-size:14px; }

    /* Position */
    .td-pos { font-family:'Bebas Neue',sans-serif; font-size:18px; color:rgba(255,255,255,0.5); width:44px; }
    .td-pos.top { color:#FFD700; }

    /* Team */
    .td-team { text-align:left !important; padding-left:18px !important; }
    .team-inner { display:flex; align-items:center; gap:12px; }
    .team-crest { width:30px; height:30px; object-fit:contain; flex-shrink:0; transition:transform 0.2s; }
    .standings-table tbody tr:hover .team-crest { transform:scale(1.15); }
    .team-name { font-weight:700; font-size:14px; color:white; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:200px; }
    .team-name a { color:white; text-decoration:none; transition:color 0.2s; }
    .team-name a:hover { color:#FFD700; }

    /* Stats */
    .td-pts { font-family:'Bebas Neue',sans-serif; font-size:22px; color:#FFD700; }
    .td-gd { font-weight:700; font-size:13px; }
    .gd-pos { color:#00c864; }
    .gd-neg { color:#ff6464; }
    .gd-zero { color:rgba(255,255,255,0.3); }

    /* Zone bars */
    .zone-cl  { border-left:3px solid #3b82f6; }
    .zone-el  { border-left:3px solid #f97316; }
    .zone-ecl { border-left:3px solid #22c55e; }
    .zone-rel { border-left:3px solid #ef4444; }

    /* Form dots */
    .form-wrap { display:flex; gap:3px; justify-content:center; }
    .form-dot { width:9px; height:9px; border-radius:50%; }
    .form-w { background:#00c864; }
    .form-d { background:rgba(255,255,255,0.25); }
    .form-l { background:#ff6464; }

    /* LOADING */
    .loading-box { display:flex; flex-direction:column; align-items:center; padding:60px 20px; gap:16px; }
    .spinner { width:44px; height:44px; border:3px solid rgba(255,215,0,0.1); border-top-color:#FFD700; border-radius:50%; animation:spin 0.8s linear infinite; }
    @keyframes spin { to{transform:rotate(360deg)} }
    .loading-box p { color:rgba(255,255,255,0.4); font-size:14px; }

    /* ERROR */
    .error-box { text-align:center; padding:48px 20px; }
    .error-box .ei { font-size:48px; margin-bottom:12px; }
    .error-box p { color:rgba(255,100,100,0.8); font-size:15px; margin-bottom:20px; }
    .retry-btn { background:rgba(255,215,0,0.12); border:1px solid rgba(255,215,0,0.3); color:#FFD700; padding:11px 28px; border-radius:10px; font-size:14px; font-weight:700; font-family:'DM Sans',sans-serif; cursor:pointer; transition:all 0.2s; }
    .retry-btn:hover { background:rgba(255,215,0,0.2); transform:translateY(-2px); }

    /* LEGEND */
    .legend { display:flex; gap:20px; flex-wrap:wrap; justify-content:center; padding:16px 24px; border-top:1px solid rgba(255,255,255,0.05); }
    .legend-item { display:flex; align-items:center; gap:7px; font-size:12px; color:rgba(255,255,255,0.4); }
    .legend-dot { width:10px; height:10px; border-radius:2px; flex-shrink:0; }

    footer { background:#060a10; border-top:1px solid rgba(255,215,0,0.06); text-align:center; padding:24px; font-size:13px; color:rgba(255,255,255,0.25); margin-top:60px; }

    @media(max-width:768px) {
      header { padding:0 16px; }
      .page { padding:90px 12px 40px; }
      .page-hero h1 { font-size:42px; }
      .league-btn { padding:9px 14px; font-size:13px; }
      .hide-mob { display:none; }
      .team-name { max-width:130px; }
      .standings-table td, .standings-table th { padding:10px 8px; }
    }
  </style>
</head>
<body>

<!-- в”Ђв”Ђ NAVBAR в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ -->
