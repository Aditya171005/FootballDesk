  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'DM Sans', sans-serif; background: #0a0e17; color: white; min-height: 100vh; }

    header { background: rgba(8,12,20,0.95); backdrop-filter: blur(12px); padding: 0 40px; display: flex; justify-content: space-between; align-items: center; position: fixed; top:0; left:0; right:0; z-index: 200; height: 70px; border-bottom: 1px solid rgba(255,215,0,0.1); }
    .logo { height: 50px; width: auto; }
    nav ul { display:flex; gap:4px; list-style:none; padding:0; margin:0; align-items:center; }
    nav a { color:rgba(255,255,255,0.7); text-decoration:none; font-weight:600; font-size:13px; padding:7px 13px; border-radius:8px; transition:all 0.2s; }
    nav a:hover { color:#FFD700; background:rgba(255,215,0,0.08); }
    nav a.login-btn { background:#f70404; color:white; border-radius:20px; padding:7px 18px; }
    .nav-more { position:relative; }
    .nav-more-btn { color:rgba(255,255,255,0.7); background:none; border:none; font-weight:600; font-size:13px; padding:7px 13px; border-radius:8px; cursor:pointer; font-family:'DM Sans',sans-serif; transition:all 0.2s; display:flex; align-items:center; gap:4px; }
    .nav-more-btn:hover { color:#FFD700; background:rgba(255,215,0,0.08); }
    .nav-more-btn .arrow { font-size:10px; transition:transform 0.2s; }
    .nav-more.open .nav-more-btn .arrow { transform:rotate(180deg); }
    .more-dropdown { display:none; position:absolute; top:calc(100% + 8px); right:0; background:#0f1623; border:1px solid rgba(255,215,0,0.2); border-radius:14px; overflow:hidden; z-index:999; box-shadow:0 20px 60px rgba(0,0,0,0.7); min-width:200px; }
    .nav-more.open .more-dropdown { display:block; }
    .more-dropdown a { display:flex; align-items:center; gap:10px; padding:11px 16px; color:rgba(255,255,255,0.8); text-decoration:none; font-size:13px; font-weight:600; transition:all 0.15s; border-bottom:1px solid rgba(255,255,255,0.04); }
    .more-dropdown a:last-child { border-bottom:none; }
    .more-dropdown a:hover { background:rgba(255,215,0,0.07); color:#FFD700; }

    .page { padding: 100px 20px 60px; max-width: 1000px; margin: 0 auto; }
    .page-header { text-align:center; margin-bottom:40px; }
    .page-header h1 { font-family:'Bebas Neue',sans-serif; font-size:56px; letter-spacing:3px; }
    .page-header h1 span { color:#FFD700; }
    .page-header p { color:rgba(255,255,255,0.5); margin-top:8px; font-size:16px; }

    /* LEAGUE TABS */
    .league-tabs { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:32px; justify-content:center; }
    .league-tab {
      padding:10px 20px; border-radius:30px; border:2px solid rgba(255,255,255,0.1);
      background:transparent; color:rgba(255,255,255,0.6); font-size:13px; font-weight:700;
      cursor:pointer; transition:all 0.2s; font-family:'DM Sans',sans-serif;
    }
    .league-tab:hover { border-color:rgba(255,215,0,0.3); color:#FFD700; }
    .league-tab.active { background:#FFD700; color:#000; border-color:#FFD700; }

    /* STATS ROW */
    .stats-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px; margin-bottom:32px; }
    .stat-card { background:#0f1623; border-radius:14px; border:1px solid rgba(255,255,255,0.07); padding:20px; text-align:center; }
    .stat-card .val { font-family:'Bebas Neue',sans-serif; font-size:36px; color:#FFD700; }
    .stat-card .lbl { font-size:11px; color:rgba(255,255,255,0.4); text-transform:uppercase; letter-spacing:1px; margin-top:4px; }

    /* TIMELINE */
    .timeline { position:relative; }
    .timeline::before { content:''; position:absolute; left:50%; top:0; bottom:0; width:2px; background:rgba(255,215,0,0.1); transform:translateX(-50%); }
    .timeline-item { display:grid; grid-template-columns:1fr 60px 1fr; gap:0; margin-bottom:16px; align-items:center; }
    .timeline-item:nth-child(odd) .tl-content { grid-column:1; text-align:right; padding-right:24px; }
    .timeline-item:nth-child(odd) .tl-empty { grid-column:3; }
    .timeline-item:nth-child(even) .tl-content { grid-column:3; text-align:left; padding-left:24px; }
    .timeline-item:nth-child(even) .tl-empty { grid-column:1; }

    .tl-dot { grid-column:2; width:48px; height:48px; border-radius:50%; background:#0f1623; border:2px solid rgba(255,215,0,0.3); display:flex; align-items:center; justify-content:center; font-family:'Bebas Neue',sans-serif; font-size:13px; color:#FFD700; z-index:1; margin:0 auto; transition:all 0.2s; cursor:pointer; }
    .tl-dot:hover { border-color:#FFD700; background:rgba(255,215,0,0.1); }
    .tl-dot.champion-year { border-color:#FFD700; background:rgba(255,215,0,0.08); }

    .tl-content { }
    .tl-card {
      background:#0f1623; border-radius:12px; border:1px solid rgba(255,255,255,0.07);
      padding:14px 16px; transition:all 0.2s; cursor:pointer;
    }
    .tl-card:hover { border-color:rgba(255,215,0,0.25); background:rgba(255,215,0,0.04); }
    .tl-year { font-family:'Bebas Neue',sans-serif; font-size:13px; color:rgba(255,215,0,0.7); letter-spacing:1px; }
    .tl-team { font-weight:700; font-size:15px; color:white; margin:2px 0; }
    .tl-detail { font-size:12px; color:rgba(255,255,255,0.4); }
    .tl-trophy { font-size:16px; }

    /* MOST TITLES */
    .most-titles { background:#0f1623; border-radius:16px; border:1px solid rgba(255,215,0,0.12); padding:28px; margin-bottom:32px; }
    .most-titles h3 { font-family:'Bebas Neue',sans-serif; font-size:22px; color:white; margin-bottom:16px; }
    .title-bar-item { display:flex; align-items:center; gap:12px; margin-bottom:12px; }
    .title-bar-name { font-weight:700; font-size:14px; min-width:140px; }
    .title-bar-bg { flex:1; height:10px; background:rgba(255,255,255,0.06); border-radius:5px; overflow:hidden; }
    .title-bar-fill { height:100%; border-radius:5px; background:linear-gradient(90deg,#FFD700,#FFA500); }
    .title-bar-count { font-family:'Bebas Neue',sans-serif; font-size:18px; color:#FFD700; min-width:28px; text-align:right; }

    footer { background:#080c14; border-top:1px solid rgba(255,215,0,0.08); text-align:center; padding:24px; font-size:13px; color:rgba(255,255,255,0.3); margin-top:60px; }

    @media(max-width:640px) {
      .timeline::before { left:24px; }
      .timeline-item { grid-template-columns:48px 1fr; }
      .timeline-item:nth-child(odd) .tl-content,
      .timeline-item:nth-child(even) .tl-content { grid-column:2; text-align:left; padding-left:16px; padding-right:0; }
      .timeline-item:nth-child(odd) .tl-empty,
      .timeline-item:nth-child(even) .tl-empty { display:none; }
      .tl-dot { grid-column:1; }
    }
  </style>
</head>
