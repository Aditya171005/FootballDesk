          { year: 2002, team: 'Lyon', pts: 66, note: 'First ever title for Lyon' },
          { year: 2001, team: 'Nantes', pts: 65, note: 'Last non-big club winner' },
          { year: 2000, team: 'Monaco', pts: 65, note: 'Henry\'s final French season' },
          { year: 1999, team: 'Lens', pts: 64, note: 'Surprise champions' },
          { year: 1998, team: 'Lens', pts: 68, note: 'Deschamps won WC that year' },
          { year: 1997, team: 'Monaco', pts: 70, note: 'Wenger years over' },
          { year: 1996, team: 'Auxerre', pts: 60, note: 'Guy Roux legend' },
        ]
      }
    };

    let currentLeague = 'PL';

    function showLeague(code) {
      currentLeague = code;
      document.querySelectorAll('.league-tab').forEach(t => t.classList.remove('active'));
      event.target.classList.add('active');
      render();
    }

    function render() {
      const data = HISTORY[currentLeague];
      const champs = data.champions;

      // Count titles
      const titleCount = {};
      champs.forEach(c => { titleCount[c.team] = (titleCount[c.team] || 0) + 1; });
      const sorted = Object.entries(titleCount).sort((a,b) => b[1]-a[1]);
      const maxTitles = sorted[0][1];

      // Stats row
      document.getElementById('stats-row').innerHTML = `
        <div class="stat-card"><div class="val">${champs.length}</div><div class="lbl">Seasons Tracked</div></div>
        <div class="stat-card"><div class="val">${sorted.length}</div><div class="lbl">Different Champions</div></div>
        <div class="stat-card"><div class="val">${maxTitles}</div><div class="lbl">Most Titles (${sorted[0][0]})</div></div>
        <div class="stat-card"><div class="val">${data.founded}</div><div class="lbl">League Founded</div></div>
      `;

      // Most titles
      document.getElementById('most-titles').innerHTML = `
        <h3>🏆 Most Titles</h3>
        ${sorted.slice(0,8).map(([team, count]) => `
          <div class="title-bar-item">
            <span class="title-bar-name">${team}</span>
            <div class="title-bar-bg"><div class="title-bar-fill" style="width:${(count/maxTitles)*100}%"></div></div>
            <span class="title-bar-count">${count}</span>
          </div>
        `).join('')}
      `;

      // Timeline
      document.getElementById('timeline').innerHTML = champs.map((c, i) => `
        <div class="timeline-item">
          ${i % 2 === 0 ? `
            <div class="tl-content">
              <div class="tl-card">
                <div class="tl-year">${c.year}/${String(c.year+1).slice(2)}</div>
                <div class="tl-team">${c.team} <span class="tl-trophy">🏆</span></div>
                <div class="tl-detail">${c.pts} pts · ${c.note}</div>
              </div>
            </div>
            <div class="tl-dot champion-year">${c.year}</div>
            <div class="tl-empty"></div>
          ` : `
            <div class="tl-empty"></div>
            <div class="tl-dot champion-year">${c.year}</div>
            <div class="tl-content">
              <div class="tl-card">
                <div class="tl-year">${c.year}/${String(c.year+1).slice(2)}</div>
                <div class="tl-team">${c.team} <span class="tl-trophy">🏆</span></div>
                <div class="tl-detail">${c.pts} pts · ${c.note}</div>
              </div>
            </div>
          `}
        </div>
      `).join('');
    }

    render();
  </script>
  <script src="/javascripts/chatbot.js"></script>
</body>
</html>
